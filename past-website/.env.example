# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://deeplearningindabaxkenya.com

# ═══════════════════════════════════════════════════════════════════════
# GOOGLE ANALYTICS & SEARCH CONSOLE
# ═══════════════════════════════════════════════════════════════════════
# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-SNSGQM1YHN

# Google Search Console Verification (for HTML file method)
# Files: public/google2dQxJmgYah3tDWRrJ-SNM2ELtnFAZu2fOCuXBKDMjAk.html
#        public/google95a6ed7e783b44da.html

# ═══════════════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (SMTP)
# ═══════════════════════════════════════════════════════════════════════
# Using server72.web-hosting.com:465 (SSL/TLS)
SMTP_HOST=server72.web-hosting.com
SMTP_PORT=465
SMTP_SECURE=true

# ───────────────────────────────────────────────────────────────────────
# Email Account #1: applications@deeplearningindabaxkenya.com
# Use for: Event registrations, applications, participant communications
# ───────────────────────────────────────────────────────────────────────
SMTP_APPLICATIONS_USER=applications@deeplearningindabaxkenya.com
SMTP_APPLICATIONS_PASS=your-applications-password
SMTP_APPLICATIONS_FROM_NAME=IndabaX Kenya Applications
SMTP_APPLICATIONS_FROM_EMAIL=applications@deeplearningindabaxkenya.com

# ───────────────────────────────────────────────────────────────────────
# Email Account #2: accounts@deeplearningindabaxkenya.com
# Use for: User registration, email verification, password resets
# ───────────────────────────────────────────────────────────────────────
SMTP_ACCOUNTS_USER=accounts@deeplearningindabaxkenya.com
SMTP_ACCOUNTS_PASS=your-accounts-password
SMTP_ACCOUNTS_FROM_NAME=IndabaX Kenya
SMTP_ACCOUNTS_FROM_EMAIL=accounts@deeplearningindabaxkenya.com

# Note: Both accounts are available. The system picks the appropriate one based on email type.
# - 'applications' account: Registration confirmations, application status updates
# - 'accounts' account: Email verification, password resets, welcome emails
