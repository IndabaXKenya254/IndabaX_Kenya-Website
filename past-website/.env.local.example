# =============================================================================
# NEXT.JS BUILD CONFIGURATION
# =============================================================================

# Font loading timeout (increase if slow network)
NEXT_FONT_TIMEOUT=60000

# Disable font optimization during development (faster builds)
# Set to 'true' in production for optimized fonts
NEXT_FONT_OPTIMIZE=true

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Email sender configuration
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=IndabaX Kenya

# SMTP Configuration (if using custom SMTP)
SMTP_HOST=server72.web-hosting.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=accounts@deeplearningindabaxkenya.com
SMTP_PASSWORD=your-password

