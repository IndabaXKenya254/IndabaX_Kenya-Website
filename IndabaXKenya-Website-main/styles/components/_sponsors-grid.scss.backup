// ═══════════════════════════════════════════════════════════════════════
// INDABAX KENYA - SPONSORS GRID STYLES
// ═══════════════════════════════════════════════════════════════════════
// Dynamic sponsors listing with tier grouping and year filtering
// Created: December 28, 2025
// ═══════════════════════════════════════════════════════════════════════

.sponsors-grid-area {
  .section-description {
    max-width: 800px;
    margin: 0 auto 50px;
    color: $text-secondary;
    font-size: $font-size-lg;
    line-height: 1.8;
  }

  // Year filter tabs
  .sponsors-year-tabs {
    .btn-group {
      gap: 10px;
      flex-wrap: wrap;

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        font-weight: 600;
        border-radius: 50px !important;
        transition: all 0.3s ease;

        .badge {
          font-size: 0.75rem;
        }
      }
    }
  }

  // Tier section
  .sponsor-tier-section {
    margin-bottom: 50px;

    .partner-title {
      border-left: 4px solid $primary;
      padding-left: 20px;
      margin-bottom: 30px;

      h3 {
        font-size: 24px;
        font-weight: $font-weight-bold;
        color: $text-primary;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;

        i {
          font-size: 28px;
        }

        .badge {
          font-size: 12px;
          font-weight: 500;
        }
      }
    }

    // Tier divider
    .tier-divider {
      height: 2px;
      background: linear-gradient(to right, transparent, #e8e8e8, transparent);
      margin-top: 30px;
    }
  }

  // Sponsor card
  .sponsor-card {
    background: $background;
    border-radius: $radius-xl;
    padding: 25px;
    text-align: center;
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);
    transition: all 0.3s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;

    &:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 40px rgba(0, 0, 0, 0.1);

      .sponsor-logo {
        transform: scale(1.05);
      }
    }

    .sponsor-link {
      text-decoration: none;
      color: inherit;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 15px;
    }

    .sponsor-logo-wrapper {
      width: 100%;
      min-height: 80px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: visible;

      img {
        display: block !important;
        max-width: 150px;
        max-height: 80px;
        min-width: 50px;
        min-height: 40px;
        width: auto;
        height: auto;
        object-fit: contain;
        transition: transform 0.3s ease;
      }

      .sponsor-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #ccc;
        gap: 10px;

        i {
          font-size: 40px;
        }

        span {
          font-size: 14px;
          font-weight: 600;
          color: $text-secondary;
        }
      }
    }

    .sponsor-info {
      h5 {
        font-size: 16px;
        font-weight: $font-weight-semibold;
        color: $text-primary;
        margin: 0;
        line-height: 1.3;
      }

      .year-badge {
        display: inline-block;
        margin-top: 8px;
        padding: 2px 10px;
        font-size: 11px;
        font-weight: 600;
        color: #6c757d;
        background: #f0f0f0;
        border-radius: 20px;
      }
    }
  }

  // No results
  .no-results {
    h3 {
      font-size: 24px;
      font-weight: $font-weight-bold;
      color: $text-primary;
    }
  }

  // CTA card
  .sponsor-cta {
    .cta-card {
      h3 {
        font-size: 28px;
        font-weight: $font-weight-bold;
      }

      p {
        font-size: 16px;
        opacity: 0.9;
      }
    }
  }
}

// Mobile responsive
@include mobile {
  .sponsors-grid-area {
    .section-description {
      font-size: $font-size-base;
      margin-bottom: 30px;
    }

    .sponsors-year-tabs {
      .btn-group {
        gap: 8px;

        .btn {
          padding: 0.5rem 1rem;
          font-size: 14px;
        }
      }
    }

    .sponsor-tier-section {
      margin-bottom: 40px;

      .partner-title {
        h3 {
          font-size: 20px;

          i {
            font-size: 24px;
          }
        }
      }
    }

    .sponsor-card {
      padding: 20px 15px;

      .sponsor-logo-wrapper {
        min-height: 60px;

        img {
          max-height: 60px;
          min-height: 30px;
        }
      }

      .sponsor-info h5 {
        font-size: 14px;
      }
    }

    .sponsor-cta .cta-card {
      padding: 30px 20px !important;

      h3 {
        font-size: 22px;
      }

      p {
        font-size: 14px;
      }
    }
  }
}
